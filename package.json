{
  "name": "appguiroblox",
  "version": "1.0.0",
  "description": "Roblox GUI Builder",
  "main": "main.js",
  "scripts": {
    "start": "electron . --ozone-platform=x11",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.toi.robloxguibuilder",
    "productName": "Roblox GUI Builder",
    "files": [
      "index.html",
      "main.js",
      "script.js",
      "presets.js",
      "style.css"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}